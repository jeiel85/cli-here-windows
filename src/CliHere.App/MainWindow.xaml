<Window x:Class="CliHere.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:CliHere.App.Models"
        mc:Ignorable="d"
        Icon="Assets/AppIcon.ico"
        Title="{Binding AppTitle}" Height="420" Width="720">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{Binding LanguageLabel}" Width="120" VerticalAlignment="Center"/>
            <ComboBox Width="220" SelectedValue="{Binding Language}" SelectedValuePath="Tag">
                <ComboBoxItem Content="{Binding LanguageSystemLabel}" Tag="{x:Static models:LanguageMode.System}"/>
                <ComboBoxItem Content="{Binding LanguageKoreanLabel}" Tag="{x:Static models:LanguageMode.Korean}"/>
                <ComboBoxItem Content="{Binding LanguageEnglishLabel}" Tag="{x:Static models:LanguageMode.English}"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{Binding TerminalLabel}" Width="120" VerticalAlignment="Center"/>
            <ComboBox Width="220" SelectedValue="{Binding Terminal}" SelectedValuePath="Tag">
                <ComboBoxItem Content="{Binding TerminalWindowsTerminalLabel}" Tag="{x:Static models:TerminalMode.WindowsTerminal}"/>
                <ComboBoxItem Content="{Binding TerminalPowerShellLabel}" Tag="{x:Static models:TerminalMode.PowerShell}"/>
            </ComboBox>
        </StackPanel>

        <CheckBox Grid.Row="2" IsChecked="{Binding RunAsAdministrator}" Content="{Binding RunAsAdministratorLabel}" Margin="0,0,0,12"/>

        <GroupBox Grid.Row="3" Header="{Binding SupportedCliLabel}" Margin="0,0,0,12">
            <ListView ItemsSource="{Binding CliItems}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{Binding DataContext.CliColumnIdLabel, RelativeSource={RelativeSource AncestorType=ListView}}" DisplayMemberBinding="{Binding Id}" Width="90"/>
                        <GridViewColumn Header="{Binding DataContext.CliColumnNameLabel, RelativeSource={RelativeSource AncestorType=ListView}}" DisplayMemberBinding="{Binding DisplayName}" Width="140"/>
                        <GridViewColumn Header="{Binding DataContext.CliColumnCommandLabel, RelativeSource={RelativeSource AncestorType=ListView}}" DisplayMemberBinding="{Binding ExecutableName}" Width="100"/>
                        <GridViewColumn Header="{Binding DataContext.CliColumnEnabledLabel, RelativeSource={RelativeSource AncestorType=ListView}}" Width="60">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{Binding DataContext.CliColumnStatusLabel, RelativeSource={RelativeSource AncestorType=ListView}}" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DataContext.NotInstalledStatusLabel, RelativeSource={RelativeSource AncestorType=ListView}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                        <Setter Property="Text" Value="{Binding DataContext.InstalledStatusLabel, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{Binding DataContext.CliColumnActionsLabel, RelativeSource={RelativeSource AncestorType=ListView}}" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Margin="0,0,6,0"
                                                Padding="8,2"
                                                Content="{Binding DataContext.InstallLinkLabel, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                Command="{Binding DataContext.OpenInstallLinkCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Padding="8,2"
                                                Content="{Binding DataContext.DocsLinkLabel, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                Command="{Binding DataContext.OpenDocsLinkCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentVersionLabel}" FontSize="12" Opacity="0.8"/>
                <TextBlock Text="{Binding UpdateCheckLabel}" FontSize="11" Opacity="0.8"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding CheckUpdateLabel}" Width="120" Margin="0,0,8,0" Command="{Binding CheckUpdateCommand}"/>
            <Button Content="{Binding RefreshLabel}" Width="100" Margin="0,0,8,0" Command="{Binding RefreshCommand}"/>
            <Button Content="{Binding RemoveAllLabel}" Width="120" Margin="0,0,8,0" Command="{Binding RemoveAllCommand}"/>
            <Button Content="{Binding ApplyLabel}" Width="100" Command="{Binding ApplyCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
